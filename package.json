{
  "name": "opencode-remote",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @opencode-remote/shared && npm run build --workspace @opencode-remote/gateway && npm run typecheck --workspace @opencode-remote/mobile",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace @opencode-remote/gateway",
    "dev:gateway": "npm run dev --workspace @opencode-remote/gateway",
    "dev:mobile": "npm run dev --workspace @opencode-remote/mobile",
    "build:android:release": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-release.ps1"
  },
  "overrides": {
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
